'use client';

import { useEffect, useRef, useState, useCallback } from 'react';
import dynamic from 'next/dynamic';
import JourneyPlayer, { JourneyStop } from './JourneyPlayer';
import JourneyCard from './JourneyCard';

const GlobeGL = dynamic(() => import('react-globe.gl'), {
  ssr: false,
  loading: () => (
    <div className="flex items-center justify-center h-full">
      <div className="text-white/60">Loading globe...</div>
    </div>
  ),
});

interface Person {
  id: string;
  name: string;
  birth: number | null;
  death: number | null;
  type: string;
  eventTypes?: string[];
}

interface Location {
  id: number;
  name: string;
  lat: number;
  lng: number;
  city: string;
  state: string;
  country: string;
  people: Person[];
}

interface Arc {
  person_id: string;
  from: { place: string; lat: number; lng: number; year?: number };
  to: { place: string; lat: number; lng: number; year?: number };
}

interface GlobeData {
  locations: Location[];
  arcs: Arc[];
}

interface JourneyModeData {
  personId: string;
  personName: string;
  birthYear: number | null;
  deathYear: number | null;
  stops: JourneyStop[];
}

interface GlobeProps {
  onPersonSelect?: (personId: string) => void;
  journeyMode?: JourneyModeData | null;
  onJourneyClose?: () => void;
}

interface SelectedRoute {
  fromPlace: string;
  toPlace: string;
  fromLat: number;
  fromLng: number;
  toLat: number;
  toLng: number;
  people: Array<{
    id: string;
    name: string;
    yearFrom?: number;
    yearTo?: number;
  }>;
}

// Calculate great-circle distance between two points using Haversine formula
function haversineDistance(lat1: number, lng1: number, lat2: number, lng2: number): number {
  const R = 6371; // Earth's radius in km
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const a =
    Math.sin(dLat/2) * Math.sin(dLat/2) +
    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
    Math.sin(dLng/2) * Math.sin(dLng/2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c; // Distance in km
}

// Scale arc altitude based on distance
// Short trips (within a state) get low arcs, transatlantic crossings get dramatic high arcs
function getArcAltitude(distanceKm: number, isSelected: boolean): number {
  const minAlt = 0.015;  // Very short trips barely rise
  const maxAlt = isSelected ? 0.4 : 0.3;  // Transatlantic gets dramatic arc

  // Use logarithmic scaling for natural-feeling progression
  // ~100km -> 0.02, ~500km -> 0.05, ~2000km -> 0.12, ~8000km -> 0.25
  if (distanceKm < 50) return minAlt;  // Same city/county - minimal arc

  const normalized = Math.log10(distanceKm / 50) / Math.log10(400); // 50km to 20000km range
  const altitude = minAlt + (maxAlt - minAlt) * Math.min(Math.max(normalized, 0), 1);

  return altitude;
}

export default function Globe({ onPersonSelect, journeyMode, onJourneyClose }: GlobeProps) {
  const globeRef = useRef<any>(null);
  const [globeData, setGlobeData] = useState<GlobeData | null>(null);
  const [selectedLocation, setSelectedLocation] = useState<Location | null>(null);
  const [selectedRoute, setSelectedRoute] = useState<SelectedRoute | null>(null);
  const [selectedPersonId, setSelectedPersonId] = useState<string | null>(null);
  const [dimensions, setDimensions] = useState({ width: 800, height: 600 });

  // Journey mode state
  const [journeyIndex, setJourneyIndex] = useState(0);
  const [isPlaying, setIsPlaying] = useState(false);
  const [playSpeed, setPlaySpeed] = useState<1 | 2 | 3>(1);
  const playIntervalRef = useRef<NodeJS.Timeout | null>(null);

  // Load globe data
  useEffect(() => {
    fetch('/data/globe.json')
      .then((res) => res.json())
      .then((data: GlobeData) => {
        setGlobeData(data);
      })
      .catch((err) => console.error('Failed to load globe data:', err));
  }, []);

  // Handle window resize
  useEffect(() => {
    const handleResize = () => {
      const panelWidth = (selectedLocation || selectedRoute) ? 400 : 0;
      setDimensions({
        width: window.innerWidth - panelWidth,
        height: window.innerHeight,
      });
    };

    handleResize();
    window.addEventListener('resize', handleResize);
    return () => window.removeEventListener('resize', handleResize);
  }, [selectedLocation, selectedRoute]);

  // Handle globe ready - set initial position centered on USA
  const handleGlobeReady = useCallback(() => {
    if (globeRef.current) {
      // Set initial position immediately (no animation)
      globeRef.current.pointOfView({ lat: 39, lng: -95, altitude: 2.0 }, 0);

      // Disable auto-rotate - keep globe static until user interacts
      if (globeRef.current.controls()) {
        globeRef.current.controls().autoRotate = false;
      }
    }
  }, []);

  // Stop rotation when location selected
  useEffect(() => {
    if (globeRef.current && selectedLocation) {
      globeRef.current.controls().autoRotate = false;
      globeRef.current.pointOfView(
        { lat: selectedLocation.lat, lng: selectedLocation.lng, altitude: 1.5 },
        1000
      );
    }
  }, [selectedLocation]);

  // Journey mode: Reset index when journey changes
  useEffect(() => {
    if (journeyMode) {
      setJourneyIndex(0);
      setIsPlaying(false);
      // Close side panel when entering journey mode
      setSelectedLocation(null);
      setSelectedPersonId(null);
    }
  }, [journeyMode?.personId]);

  // Journey mode: Animate camera to current stop
  useEffect(() => {
    if (journeyMode && globeRef.current) {
      const stop = journeyMode.stops[journeyIndex];
      if (stop?.lat && stop?.lng) {
        // Small delay to ensure globe is ready after mode change
        const timer = setTimeout(() => {
          if (globeRef.current) {
            globeRef.current.controls().autoRotate = false;
            // Zoom in close for immersive experience
            globeRef.current.pointOfView(
              { lat: stop.lat, lng: stop.lng, altitude: 0.3 },
              1500 / playSpeed  // Smooth animation
            );
          }
        }, journeyIndex === 0 ? 300 : 0);  // Delay only on first stop
        return () => clearTimeout(timer);
      }
    }
  }, [journeyMode, journeyIndex, playSpeed]);

  // Journey mode: Auto-play interval
  useEffect(() => {
    if (journeyMode && isPlaying) {
      const interval = 4000 / playSpeed;  // Base 4 seconds, faster with speed
      playIntervalRef.current = setInterval(() => {
        setJourneyIndex((prev) => {
          if (prev >= journeyMode.stops.length - 1) {
            setIsPlaying(false);
            return prev;
          }
          return prev + 1;
        });
      }, interval);
    }

    return () => {
      if (playIntervalRef.current) {
        clearInterval(playIntervalRef.current);
      }
    };
  }, [journeyMode, isPlaying, playSpeed]);

  // Journey mode handlers
  const handleJourneyPlayPause = useCallback(() => {
    setIsPlaying((prev) => !prev);
  }, []);

  const handleJourneyIndexChange = useCallback((index: number) => {
    setJourneyIndex(index);
  }, []);

  const handleJourneySpeedChange = useCallback((speed: 1 | 2 | 3) => {
    setPlaySpeed(speed);
  }, []);

  const handleJourneyClose = useCallback(() => {
    setIsPlaying(false);
    if (playIntervalRef.current) {
      clearInterval(playIntervalRef.current);
    }
    if (onJourneyClose) {
      onJourneyClose();
    }
  }, [onJourneyClose]);

  // Get arcs for selected person (for sidebar display)
  const selectedPersonArcs = selectedPersonId
    ? globeData?.arcs.filter((arc) => arc.person_id === selectedPersonId) || []
    : [];

  // Compute journey summary for selected person
  const journeySummary = selectedPersonArcs.length > 0 ? {
    origin: selectedPersonArcs[0]?.from?.place?.split(',')[0] || '?',
    destination: selectedPersonArcs[selectedPersonArcs.length - 1]?.to?.place?.split(',')[0] || '?',
    originState: selectedPersonArcs[0]?.from?.place?.split(',').slice(-2, -1)[0]?.trim() || '',
    destState: selectedPersonArcs[selectedPersonArcs.length - 1]?.to?.place?.split(',').slice(-2, -1)[0]?.trim() || '',
  } : null;

  const getPointColor = useCallback((location: Location) => {
    const colors: Record<string, string> = {
      'England': '#e63946',
      'Wales': '#2a9d8f',
      'Scotland': '#457b9d',
      'USA': '#f4a261',
      'Germany': '#e9c46a',
    };
    return colors[location.country] || '#8d99ae';
  }, []);

  const handleLocationClick = (point: any) => {
    setSelectedLocation(point as Location);
    setSelectedRoute(null);
    setSelectedPersonId(null);
  };

  const handleArcClick = (arc: any) => {
    if (!globeData) return;

    // Build a map of person_id to name from locations
    const personNames: Record<string, string> = {};
    for (const loc of globeData.locations) {
      for (const person of loc.people) {
        personNames[person.id] = person.name;
      }
    }

    // Find all arcs with same route (within 0.1 degree tolerance for matching)
    const matchingArcs = globeData.arcs.filter((a: Arc) => {
      const fromMatch = Math.abs(a.from.lat - arc.from.lat) < 0.1 &&
                        Math.abs(a.from.lng - arc.from.lng) < 0.1;
      const toMatch = Math.abs(a.to.lat - arc.to.lat) < 0.1 &&
                      Math.abs(a.to.lng - arc.to.lng) < 0.1;
      return fromMatch && toMatch;
    });

    // Build people list for this route (look up names from locations)
    const people = matchingArcs.map((a: Arc) => ({
      id: a.person_id,
      name: personNames[a.person_id] || a.person_id,
      yearFrom: a.from?.year,
      yearTo: a.to?.year,
    }));

    setSelectedRoute({
      fromPlace: arc.from?.place?.split(',')[0] || '?',
      toPlace: arc.to?.place?.split(',')[0] || '?',
      fromLat: arc.from.lat,
      fromLng: arc.from.lng,
      toLat: arc.to.lat,
      toLng: arc.to.lng,
      people,
    });
    setSelectedLocation(null);
    setSelectedPersonId(null);
  };

  const handlePersonClick = (person: Person) => {
    setSelectedPersonId(person.id);
    if (onPersonSelect) {
      onPersonSelect(person.id);
    }
  };

  const handleRoutePersonClick = (personId: string) => {
    setSelectedPersonId(personId);
    if (onPersonSelect) {
      onPersonSelect(personId);
    }
  };

  const closePanel = () => {
    setSelectedLocation(null);
    setSelectedRoute(null);
    setSelectedPersonId(null);
  };

  if (!globeData) {
    return (
      <div className="flex items-center justify-center h-full bg-black">
        <div className="text-white/60">Loading family history...</div>
      </div>
    );
  }

  return (
    <div className="relative w-full h-full bg-black flex">
      {/* Globe */}
      <div className="flex-1 relative">
        <GlobeGL
          ref={globeRef}
          width={dimensions.width}
          height={dimensions.height}
          onGlobeReady={handleGlobeReady}
          globeImageUrl="//unpkg.com/three-globe/example/img/earth-blue-marble.jpg"
          bumpImageUrl="//unpkg.com/three-globe/example/img/earth-topology.png"
          backgroundImageUrl="//unpkg.com/three-globe/example/img/night-sky.png"
          pointsData={globeData.locations}
          pointLat={(d: any) => d.lat}
          pointLng={(d: any) => d.lng}
          pointColor={(d: any) => getPointColor(d)}
          pointAltitude={0.01}
          pointRadius={(d: any) => {
            const count = Array.isArray(d.people) ? d.people.length : 0;
            return Math.max(0.2, Math.min(0.6, count * 0.05));
          }}
          pointLabel={(d: any) => {
            const count = Array.isArray(d.people) ? d.people.length : 0;
            return `
              <div style="background: rgba(0,0,0,0.9); color: white; padding: 10px 14px; border-radius: 8px; font-size: 14px; pointer-events: none;">
                <div style="font-weight: 600; margin-bottom: 4px;">${d.name}</div>
                <div style="opacity: 0.7;">${count} ${count === 1 ? 'person' : 'people'}</div>
                <div style="opacity: 0.5; font-size: 12px; margin-top: 4px;">Click to explore</div>
              </div>
            `;
          }}
          onPointClick={handleLocationClick}
          arcsData={globeData.arcs}
          arcStartLat={(d: any) => d.from.lat}
          arcStartLng={(d: any) => d.from.lng}
          arcEndLat={(d: any) => d.to.lat}
          arcEndLng={(d: any) => d.to.lng}
          arcColor={(d: any) => {
            const isPersonSelected = selectedPersonId && d.person_id === selectedPersonId;
            const isRouteSelected = selectedRoute &&
              Math.abs(d.from.lat - selectedRoute.fromLat) < 0.1 &&
              Math.abs(d.from.lng - selectedRoute.fromLng) < 0.1 &&
              Math.abs(d.to.lat - selectedRoute.toLat) < 0.1 &&
              Math.abs(d.to.lng - selectedRoute.toLng) < 0.1;
            const isSelected = isPersonSelected || isRouteSelected;
            if (isSelected) {
              return ['#ff6b6b', '#ffd93d']; // Bright gradient for selected
            }
            return (selectedPersonId || selectedRoute)
              ? ['rgba(255,107,107,0.15)', 'rgba(255,217,61,0.15)'] // Faded when something else selected
              : ['rgba(255,107,107,0.4)', 'rgba(255,217,61,0.4)']; // Default subtle
          }}
          arcAltitude={(d: any) => {
            const isPersonSelected = selectedPersonId && d.person_id === selectedPersonId;
            const isRouteSelected = selectedRoute &&
              Math.abs(d.from.lat - selectedRoute.fromLat) < 0.1 &&
              Math.abs(d.from.lng - selectedRoute.fromLng) < 0.1 &&
              Math.abs(d.to.lat - selectedRoute.toLat) < 0.1 &&
              Math.abs(d.to.lng - selectedRoute.toLng) < 0.1;
            const isSelected = !!(isPersonSelected || isRouteSelected);

            // Calculate distance and scale arc height accordingly
            const distance = haversineDistance(d.from.lat, d.from.lng, d.to.lat, d.to.lng);
            return getArcAltitude(distance, isSelected);
          }}
          arcStroke={(d: any) => {
            const isPersonSelected = selectedPersonId && d.person_id === selectedPersonId;
            const isRouteSelected = selectedRoute &&
              Math.abs(d.from.lat - selectedRoute.fromLat) < 0.1 &&
              Math.abs(d.from.lng - selectedRoute.fromLng) < 0.1 &&
              Math.abs(d.to.lat - selectedRoute.toLat) < 0.1 &&
              Math.abs(d.to.lng - selectedRoute.toLng) < 0.1;
            return (isPersonSelected || isRouteSelected) ? 1.5 : 0.3;
          }}
          arcDashLength={(d: any) => {
            const isPersonSelected = selectedPersonId && d.person_id === selectedPersonId;
            const isRouteSelected = selectedRoute &&
              Math.abs(d.from.lat - selectedRoute.fromLat) < 0.1 &&
              Math.abs(d.from.lng - selectedRoute.fromLng) < 0.1 &&
              Math.abs(d.to.lat - selectedRoute.toLat) < 0.1 &&
              Math.abs(d.to.lng - selectedRoute.toLng) < 0.1;
            return (isPersonSelected || isRouteSelected) ? 0.5 : 0.9;
          }}
          arcDashGap={(d: any) => {
            const isPersonSelected = selectedPersonId && d.person_id === selectedPersonId;
            const isRouteSelected = selectedRoute &&
              Math.abs(d.from.lat - selectedRoute.fromLat) < 0.1 &&
              Math.abs(d.from.lng - selectedRoute.fromLng) < 0.1 &&
              Math.abs(d.to.lat - selectedRoute.toLat) < 0.1 &&
              Math.abs(d.to.lng - selectedRoute.toLng) < 0.1;
            return (isPersonSelected || isRouteSelected) ? 0.25 : 0.1;
          }}
          arcDashAnimateTime={(d: any) => {
            const isPersonSelected = selectedPersonId && d.person_id === selectedPersonId;
            const isRouteSelected = selectedRoute &&
              Math.abs(d.from.lat - selectedRoute.fromLat) < 0.1 &&
              Math.abs(d.from.lng - selectedRoute.fromLng) < 0.1 &&
              Math.abs(d.to.lat - selectedRoute.toLat) < 0.1 &&
              Math.abs(d.to.lng - selectedRoute.toLng) < 0.1;
            return (isPersonSelected || isRouteSelected) ? 1500 : 0;
          }}
          arcLabel={(d: any) => `
            <div style="background: rgba(0,0,0,0.9); color: white; padding: 8px 12px; border-radius: 6px;">
              <div style="font-weight: 600;">${d.from?.place?.split(',')[0] || '?'} → ${d.to?.place?.split(',')[0] || '?'}</div>
              <div style="opacity: 0.7; font-size: 12px;">${d.from?.year || '?'} → ${d.to?.year || '?'}</div>
              <div style="opacity: 0.5; font-size: 11px; margin-top: 4px;">Click to see travelers</div>
            </div>
          `}
          onArcClick={handleArcClick}
          atmosphereColor="#3a86ff"
          atmosphereAltitude={0.15}
        />

        {/* Journey Mode: Narrative Card */}
        {journeyMode && journeyMode.stops[journeyIndex] && (
          <JourneyCard
            stop={journeyMode.stops[journeyIndex]}
            personName={journeyMode.personName}
            birthYear={journeyMode.birthYear}
            stopIndex={journeyIndex}
            totalStops={journeyMode.stops.length}
            isFirst={journeyIndex === 0}
            isLast={journeyIndex === journeyMode.stops.length - 1}
          />
        )}

        {/* Journey Mode: Player Controls */}
        {journeyMode && (
          <JourneyPlayer
            personName={journeyMode.personName}
            birthYear={journeyMode.birthYear}
            deathYear={journeyMode.deathYear}
            stops={journeyMode.stops}
            currentIndex={journeyIndex}
            isPlaying={isPlaying}
            speed={playSpeed}
            onIndexChange={handleJourneyIndexChange}
            onPlayPause={handleJourneyPlayPause}
            onSpeedChange={handleJourneySpeedChange}
            onClose={handleJourneyClose}
          />
        )}

        {/* Legend - hidden in journey mode */}
        {!journeyMode && (
          <div className="absolute bottom-20 left-4 bg-black/80 backdrop-blur-sm rounded-lg p-4 text-white text-sm z-10">
            <div className="font-semibold mb-3">Locations by Region</div>
            <div className="space-y-2">
              <div className="flex items-center gap-3">
                <span className="w-3 h-3 rounded-full bg-[#e63946] flex-shrink-0"></span>
                <span>England</span>
              </div>
              <div className="flex items-center gap-3">
                <span className="w-3 h-3 rounded-full bg-[#2a9d8f] flex-shrink-0"></span>
                <span>Wales</span>
              </div>
              <div className="flex items-center gap-3">
                <span className="w-3 h-3 rounded-full bg-[#457b9d] flex-shrink-0"></span>
                <span>Scotland</span>
              </div>
              <div className="flex items-center gap-3">
                <span className="w-3 h-3 rounded-full bg-[#f4a261] flex-shrink-0"></span>
                <span>USA</span>
              </div>
              <div className="flex items-center gap-3">
                <span className="w-3 h-3 rounded-full bg-[#8d99ae] flex-shrink-0"></span>
                <span>Other</span>
              </div>
            </div>
          </div>
        )}

        {/* Stats - hidden in journey mode */}
        {!journeyMode && (
          <div className="absolute top-4 right-4 bg-black/80 backdrop-blur-sm rounded-lg p-4 text-white text-sm z-10">
            <div className="font-semibold mb-2">Watson Family Tree</div>
            <div className="text-white/70">{globeData.locations.length} locations</div>
            <div className="text-white/70">{globeData.arcs.length} migration paths</div>
          </div>
        )}

        {/* Instructions - hidden in journey mode or when panel open */}
        {!selectedLocation && !selectedRoute && !journeyMode && (
          <div className="absolute bottom-20 right-4 bg-black/80 backdrop-blur-sm rounded-lg p-4 text-white text-sm z-10 max-w-xs">
            <div className="font-semibold mb-2">How to explore</div>
            <ul className="text-white/70 space-y-1 text-xs">
              <li>• Drag to rotate the globe</li>
              <li>• Scroll to zoom in/out</li>
              <li>• Click a location to see people</li>
              <li>• Click an arc to see travelers</li>
            </ul>
          </div>
        )}
      </div>

      {/* Side Panel - hidden in journey mode */}
      {selectedLocation && !journeyMode && (
        <div className="w-[400px] bg-gray-900 border-l border-gray-700 overflow-y-auto">
          {/* Header */}
          <div className="sticky top-0 bg-gray-900 border-b border-gray-700 p-4 z-10">
            <div className="flex items-start justify-between">
              <div>
                <h2 className="text-xl font-semibold text-white">{selectedLocation.name}</h2>
                <p className="text-gray-400 text-sm mt-1">
                  {selectedLocation.country}
                  {selectedLocation.state && ` • ${selectedLocation.state}`}
                </p>
              </div>
              <button
                onClick={closePanel}
                className="text-gray-400 hover:text-white p-1"
              >
                <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>

          {/* People List */}
          <div className="p-4">
            <h3 className="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">
              People ({selectedLocation.people.length})
            </h3>
            <div className="space-y-2">
              {selectedLocation.people.map((person, idx) => (
                <button
                  key={`${person.id}-${idx}`}
                  onClick={() => handlePersonClick(person)}
                  className={`w-full text-left p-3 rounded-lg transition-colors ${
                    selectedPersonId === person.id
                      ? 'bg-blue-600 text-white'
                      : 'bg-gray-800 hover:bg-gray-700 text-white'
                  }`}
                >
                  <div className="font-medium">{person.name}</div>
                  <div className="text-sm opacity-70 mt-1">
                    {person.birth && person.death
                      ? `${person.birth} - ${person.death}`
                      : person.birth
                      ? `b. ${person.birth}`
                      : person.death
                      ? `d. ${person.death}`
                      : 'Dates unknown'}
                    {person.eventTypes && person.eventTypes.length > 0 && (
                      <span className="ml-2 text-xs opacity-50">
                        ({person.eventTypes.map((t: string) =>
                          t === 'birth' ? 'Born'
                          : t === 'death' ? 'Died'
                          : t === 'residence' ? 'Lived'
                          : t === 'marriage' ? 'Married'
                          : t === 'census' ? 'Census'
                          : t === 'school' ? 'School'
                          : t
                        ).join(', ')})
                      </span>
                    )}
                  </div>
                </button>
              ))}
            </div>

            {/* Selected Person Details */}
            {selectedPersonId && (
              <div className="mt-6 p-4 bg-gray-800 rounded-lg">
                {journeySummary ? (
                  <div className="text-center mb-4">
                    <div className="text-2xl text-white font-light tracking-wide">
                      {journeySummary.origin}
                      <span className="mx-3 text-gray-500">→</span>
                      {journeySummary.destination}
                    </div>
                    <div className="text-sm text-gray-500 mt-1">
                      {journeySummary.originState && journeySummary.destState &&
                        journeySummary.originState !== journeySummary.destState
                        ? `${journeySummary.originState} to ${journeySummary.destState}`
                        : selectedPersonArcs.length > 1
                          ? `${selectedPersonArcs.length} migrations`
                          : '1 migration'
                      }
                    </div>
                  </div>
                ) : (
                  <p className="text-gray-500 text-sm text-center mb-4">No migration data</p>
                )}
                <a
                  href={`/person/${selectedPersonId}`}
                  className="block w-full text-center bg-blue-600 hover:bg-blue-500 text-white py-2 px-4 rounded-lg transition-colors"
                >
                  View Full Story →
                </a>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Route Panel - hidden in journey mode */}
      {selectedRoute && !journeyMode && (
        <div className="w-[400px] bg-gray-900 border-l border-gray-700 overflow-y-auto">
          {/* Header */}
          <div className="sticky top-0 bg-gray-900 border-b border-gray-700 p-4 z-10">
            <div className="flex items-start justify-between">
              <div>
                <h2 className="text-xl font-semibold text-white">
                  {selectedRoute.fromPlace} → {selectedRoute.toPlace}
                </h2>
                <p className="text-gray-400 text-sm mt-1">
                  Migration Route
                </p>
              </div>
              <button
                onClick={closePanel}
                className="text-gray-400 hover:text-white p-1"
              >
                <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>

          {/* Travelers List */}
          <div className="p-4">
            <h3 className="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">
              Travelers ({selectedRoute.people.length})
            </h3>
            <div className="space-y-2">
              {selectedRoute.people.map((person, idx) => (
                <button
                  key={`${person.id}-${idx}`}
                  onClick={() => handleRoutePersonClick(person.id)}
                  className={`w-full text-left p-3 rounded-lg transition-colors ${
                    selectedPersonId === person.id
                      ? 'bg-blue-600 text-white'
                      : 'bg-gray-800 hover:bg-gray-700 text-white'
                  }`}
                >
                  <div className="font-medium">{person.name}</div>
                  <div className="text-sm opacity-70 mt-1">
                    {person.yearFrom && person.yearTo
                      ? `${person.yearFrom} → ${person.yearTo}`
                      : person.yearFrom
                        ? `from ${person.yearFrom}`
                        : person.yearTo
                          ? `to ${person.yearTo}`
                          : 'Dates unknown'}
                  </div>
                </button>
              ))}
            </div>

            {/* Selected Person Link */}
            {selectedPersonId && (
              <div className="mt-6 p-4 bg-gray-800 rounded-lg">
                <a
                  href={`/person/${selectedPersonId}`}
                  className="block w-full text-center bg-blue-600 hover:bg-blue-500 text-white py-2 px-4 rounded-lg transition-colors"
                >
                  View Full Story →
                </a>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
