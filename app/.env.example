# Watson Family Archive — local environment template
#
# Copy this file to .env.local and fill in values for local development.
# This is a public read-only archive: auth is disabled by default and
# most secrets are optional.

# ─── Neo4j (required for the app to run) ─────────────────────────
# Default values match a stock local Neo4j install with the password "localdev".
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdev

# ─── Anthropic (optional — enables AI chat over the tree) ────────
# Without this, the AI chat panel is hidden. The globe + tree + person
# pages all work without it.
ANTHROPIC_API_KEY=

# ─── Voyage AI (optional — enables vector search) ────────────────
VOYAGE_API_KEY=
