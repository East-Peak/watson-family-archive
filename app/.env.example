# Watson Family Archive — public runtime configuration.
# Copy this file to .env.local and fill in the values for your environment.

# Neo4j (required) — the local graph database the archive reads from.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# Cesium Ion token (required for the 3D globe). Get a free token at cesium.com.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Optional — set NEXT_PUBLIC_ENABLE_CHAT to "true" AND provide an
# ANTHROPIC_API_KEY to enable the AI chat panel. Left unset, the Ask AI
# controls stay hidden and the archive makes no external API calls.
NEXT_PUBLIC_ENABLE_CHAT=
ANTHROPIC_API_KEY=
